{
  "name": "@agent-studio/ruflo-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Ruflo plugin that forwards swarm lifecycle hooks to the Agent Studio event bridge",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-studio/shared": "0.1.0",
    "@claude-flow/cli": "^3.5.0",
    "ws": "^8.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10"
  }
}
