{
  "name": "@agent-studio/electron-shell",
  "version": "0.1.0",
  "private": true,
  "description": "Electron main process — Studio Window + transparent Desktop Overlay",
  "type": "commonjs",
  "main": "./out/main/main.js",
  "scripts": {
    "build": "electron-vite build",
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "clean": "rm -rf out",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-studio/shared": "0.1.0",
    "ws": "^8.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "electron": "^31.2.0",
    "electron-vite": "^2.3.0"
  }
}
