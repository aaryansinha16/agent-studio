{
  "name": "@agent-studio/hooks-shim",
  "version": "0.1.0",
  "private": true,
  "description": "Thin CLI wrapper around 'claude-flow hooks' that mirrors each hook firing as a StudioEvent on the event bridge",
  "type": "module",
  "bin": {
    "agent-studio-hook": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-studio/shared": "0.1.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10"
  }
}
